APP_NAME=KerjaKu
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://kerjaku.example.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

KERJAKU_DISPLAY_TIMEZONE=Asia/Makassar

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kerjaku
DB_USERNAME=kerjaku
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# WAJIB ganti ke domain asli (sama persis dengan host di APP_URL, tanpa
# https:// dan tanpa slash) — kalau tidak, semua request /api/* dari browser
# akan 401 Unauthenticated meski sesi login valid, karena Sanctum menolak
# menganggap origin ini "stateful". Ini pernah kejadian di production.
SANCTUM_STATEFUL_DOMAINS=kerjaku.example.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
PHOTOS_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# php artisan webpush:vapid (jalankan di server Linux)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@example.com"

# MinIO / S3 — hanya jika PHOTOS_DISK=minio
MINIO_ACCESS_KEY_ID=
MINIO_SECRET_ACCESS_KEY=
MINIO_REGION=us-east-1
MINIO_BUCKET=
MINIO_URL=
MINIO_ENDPOINT=

VITE_APP_NAME="${APP_NAME}"
